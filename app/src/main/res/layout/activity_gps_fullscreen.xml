<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <fragment
        android:id="@+id/mapFullscreen"
        android:name="com.google.android.gms.maps.SupportMapFragment"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbarGps"
        android:layout_width="0dp"
        android:layout_height="?attr/actionBarSize"
        android:background="#CCffffff"
        android:elevation="4dp"
        app:title="GPS Location"
        app:titleTextColor="#005A9E"
        app:navigationIcon="@drawable/rounded_arrow_back"
        app:navigationIconTint="#005A9E"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardCoordInfo"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="4dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvFullFilter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Filter: Main Filter"
                android:textColor="#212121"
                android:textSize="14sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvFullCoords"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="GPS: 3.8123, 103.3256"
                android:textColor="#757575"
                android:textSize="12sp"
                android:layout_marginTop="4dp"/>

            <TextView
                android:id="@+id/tvFullDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Date: 14/06/2026"
                android:textColor="#757575"
                android:textSize="12sp"
                android:layout_marginTop="2dp"/>

            <TextView
                android:id="@+id/tvFullTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Time: 08:30 a.m."
                android:textColor="#757575"
                android:textSize="12sp"
                android:layout_marginTop="2dp"/>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
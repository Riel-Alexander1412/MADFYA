<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="180dp"
    android:background="#1A5C8F"
    android:gravity="bottom"
    android:orientation="vertical"
    android:padding="24dp">

    <ImageView
        android:id="@+id/drawer_avatar"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_marginBottom="12dp"
        android:background="@drawable/bg_badge_normal"
        android:contentDescription="Avatar"
        android:padding="12dp"
        android:src="@drawable/ic_person"
        android:tint="#1A5C8F" />

    <TextView
        android:id="@+id/drawer_user_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="User Name"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/drawer_user_role"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="Resident"
        android:textColor="#B3D9F5"
        android:textSize="13sp" />

</LinearLayout>
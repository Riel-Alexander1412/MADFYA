<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA"
    tools:context=".Status">

    <LinearLayout
        android:id="@+id/statusToolbar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:elevation="2dp"
        android:gravity="center_vertical"
        android:minHeight="56dp"
        android:orientation="horizontal"
        android:paddingHorizontal="4dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back"
            android:src="@drawable/ic_arrow_back"
            app:tint="@color/brand_blue" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:text="Water Quality Monitoring"
            android:textColor="@color/brand_blue"
            android:textSize="20sp"
            android:textStyle="bold" />

    </LinearLayout>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_nav"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        app:elevation="8dp"
        app:itemIconTint="@color/nav_selector"
        app:itemTextColor="@color/nav_selector"
        app:labelVisibilityMode="labeled"
        app:menu="@menu/menu_dashboard"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/statusToolbar"
        app:layout_constraintBottom_toTopOf="@+id/bottom_nav"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="24dp"
            android:paddingBottom="16dp">
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:strokeColor="#E0E0E0"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="20dp"
                    tools:ignore="UseCompoundDrawables">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Water Safety Score:"
                        android:textStyle="bold"
                        android:textColor="#212121"
                        tools:ignore="HardcodedText" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="84%"
                        android:textSize="48sp"
                        android:textStyle="bold"
                        android:textColor="#000000"
                        android:id="@+id/tvWaterSafetyScore"
                        tools:ignore="HardcodedText" />

                    <TextView
                        android:id="@+id/tvSafetyLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Safe For Consumption ✓"
                        android:textColor="#66BB6A"
                        android:textStyle="bold"
                        tools:ignore="HardcodedText" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/tvAlertBanner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#F5BA5C"
                android:textColor="#000000"
                android:padding="12dp"
                android:layout_marginBottom="16dp"
                android:text="pH level is above the safe threshold (8.5 pH). Filter inspection recommended."
                android:textSize="14sp"
                tools:ignore="HardcodedText" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Main Filter"
                    android:textColor="#005A9E"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    tools:ignore="HardcodedText" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnViewHistory"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:text="History"
                    android:textSize="12sp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    app:icon="@drawable/ic_history"
                    app:iconSize="14dp"
                    app:iconTint="#005A9E"
                    app:strokeColor="#005A9E"
                    android:textColor="#005A9E"
                    app:cornerRadius="20dp"/>

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_weight="1"
                    android:layout_margin="4dp"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="#FFE0B2">
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">
                        <com.github.mikephil.charting.charts.LineChart
                            android:id="@+id/PhChart"
                            android:layout_width="match_parent"
                            android:layout_height="65dp"
                            android:layout_alignParentBottom="true"
                            android:layout_marginBottom="-2dp"
                            />
                        <ImageView
                            android:id="@+id/ivPhIcon"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_marginStart="12dp"
                            android:layout_marginTop="12dp"
                            android:src="@drawable/ic_ph_level"
                            app:tint="#F57C00"
                            android:contentDescription="PH Icon" />

                        <LinearLayout
                            android:layout_width="90dp"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_marginTop="12dp"
                            android:background="@drawable/bg_status_badge"
                            android:orientation="horizontal"
                            android:gravity="center"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp">

                            <TextView
                                android:id="@+id/phStatusText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="High"
                                android:textColor="#F57C00"
                                android:textSize="11sp"
                                android:textStyle="bold"
                                tools:ignore="HardcodedText" />

                            <ImageView
                                android:id="@+id/phStatusBadge"
                                android:layout_width="12dp"
                                android:layout_height="12dp"
                                android:layout_marginStart="4dp"
                                android:src="@drawable/ic_warning"
                                app:tint="#F57C00"
                                android:contentDescription="Warning Icon" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:layout_marginStart="12dp"
                            android:text="PH Level"
                            android:textColor="#000000"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            tools:ignore="HardcodedText" />
                    </RelativeLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_weight="1"
                    android:layout_margin="4dp"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="#B2EBF2">
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">
                        <com.github.mikephil.charting.charts.LineChart
                            android:id="@+id/TurbChart"
                            android:layout_width="match_parent"
                            android:layout_height="65dp"
                            android:layout_alignParentBottom="true"
                            android:layout_marginBottom="-2dp"/>
                        <ImageView
                            android:id="@+id/ivTurbidityIcon"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_marginStart="12dp"
                            android:layout_marginTop="12dp"
                            android:src="@drawable/ic_turbidity"
                            app:tint="#00BCD4"
                            android:contentDescription="Turbidity Icon" />

                        <LinearLayout
                            android:layout_width="90dp"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_marginTop="12dp"
                            android:background="@drawable/bg_status_badge"
                            android:orientation="horizontal"
                            android:gravity="center"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp">

                            <TextView
                                android:id="@+id/TurbStatusText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Normal"
                                android:textColor="#66BB6A"
                                android:textSize="11sp"
                                android:textStyle="bold"
                                tools:ignore="HardcodedText" />

                            <ImageView
                                android:id="@+id/TurbStatusBadge"
                                android:layout_width="12dp"
                                android:layout_height="12dp"
                                android:layout_marginStart="4dp"
                                android:src="@drawable/ic_check_circle"
                                app:tint="#66BB6A"
                                android:contentDescription="Check Icon" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:layout_marginStart="12dp"
                            android:text="Turbidity"
                            android:textColor="#000000"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            tools:ignore="HardcodedText" />
                    </RelativeLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_weight="1"
                    android:layout_margin="4dp"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="#FFCDD2">
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        >
                        <com.github.mikephil.charting.charts.LineChart
                            android:id="@+id/TempChart"
                            android:layout_width="match_parent"
                            android:layout_height="65dp"
                            android:layout_alignParentBottom="true"
                            android:layout_marginBottom="-2dp"/>
                        <ImageView
                            android:id="@+id/ivTempIcon"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_marginStart="12dp"
                            android:layout_marginTop="12dp"
                            android:src="@drawable/ic_temperature"
                            app:tint="#F44336"
                            android:contentDescription="Temperature Icon" />

                        <LinearLayout
                            android:layout_width="90dp"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_marginTop="12dp"
                            android:background="@drawable/bg_status_badge"
                            android:orientation="horizontal"
                            android:gravity="center"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp">

                            <TextView
                                android:id="@+id/TempStatusText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Abnormal"
                                android:textColor="#EF5350"
                                android:textSize="11sp"
                                android:textStyle="bold"
                                tools:ignore="HardcodedText" />

                            <ImageView
                                android:id="@+id/TempStatusBagde"
                                android:layout_width="12dp"
                                android:layout_height="12dp"
                                android:layout_marginStart="4dp"
                                android:src="@drawable/ic_warning"
                                app:tint="#EF5350"
                                android:contentDescription="Warning Icon" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:layout_marginStart="12dp"
                            android:text="Temperature"
                            android:textColor="#000000"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            tools:ignore="HardcodedText" />
                    </RelativeLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_weight="1"
                    android:layout_margin="4dp"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="#C8E6C9">
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        >
                        <com.github.mikephil.charting.charts.LineChart
                            android:id="@+id/WaterChart"
                            android:layout_width="match_parent"
                            android:layout_height="65dp"
                            android:layout_alignParentBottom="true"
                            android:layout_marginBottom="-2dp"/>
                        <ImageView
                            android:id="@+id/ivWaterIcon"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_marginStart="12dp"
                            android:layout_marginTop="12dp"
                            android:src="@drawable/ic_water_usage"
                            app:tint="#4CAF50"
                            android:contentDescription="Water Usage Icon" />

                        <LinearLayout
                            android:layout_width="90dp"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_marginTop="12dp"
                            android:background="@drawable/bg_status_badge"
                            android:orientation="horizontal"
                            android:gravity="center"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp">

                            <TextView
                                android:id="@+id/waterStatusText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Normal"
                                android:textColor="#66BB6A"
                                android:textSize="11sp"
                                android:textStyle="bold"
                                tools:ignore="HardcodedText" />

                            <ImageView
                                android:id="@+id/waterStatusBadge"
                                android:layout_width="12dp"
                                android:layout_height="12dp"
                                android:layout_marginStart="4dp"
                                android:src="@drawable/ic_check_circle"
                                app:tint="#66BB6A"
                                android:contentDescription="Check Icon" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:layout_marginStart="12dp"
                            android:text="Water Usage"
                            android:textColor="#000000"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            tools:ignore="HardcodedText" />
                    </RelativeLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sub Filters"
                android:textColor="#005A9E"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"
                tools:ignore="HardcodedText" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:strokeColor="#E0E0E0"
                app:strokeWidth="1dp">
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="12dp">

                    <TextView
                        android:id="@+id/tvFilterLabelA"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Filter"
                        android:textSize="10sp"
                        android:textColor="#757575"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        tools:ignore="HardcodedText" />

                    <TextView
                        android:id="@+id/tvFilterNameA"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="A"
                        android:textSize="44sp"
                        android:textStyle="bold"
                        android:textColor="#000000"
                        app:layout_constraintTop_toBottomOf="@id/tvFilterLabelA"
                        app:layout_constraintStart_toStartOf="parent"
                        tools:ignore="HardcodedText" />

                    <LinearLayout
                        android:id="@+id/llStatusBadgeA"
                        android:layout_width="wrap_content"
                        android:layout_height="22dp"
                        android:orientation="horizontal"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintEnd_toEndOf="parent">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:text="STATUS:"
                            android:textColor="#FFFFFF"
                            android:textSize="9sp"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:background="@drawable/bg_status_left"
                            android:paddingHorizontal="8dp"
                            tools:ignore="HardcodedText" />
                        <TextView
                            android:id="@+id/subAStatText"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:text="Good"
                            android:textColor="#000000"
                            android:textSize="9sp"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:background="@drawable/bg_status_right"
                            android:paddingHorizontal="8dp"
                            app:drawableStartCompat="@drawable/ic_tick_sub"
                            android:drawablePadding="4dp"
                            tools:ignore="HardcodedText" />
                    </LinearLayout>

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/clGraphContainerA"
                        android:layout_width="0dp"
                        android:layout_height="70dp"
                        android:layout_marginStart="16dp"
                        android:layout_marginTop="4dp"
                        app:layout_constraintTop_toBottomOf="@id/llStatusBadgeA"
                        app:layout_constraintStart_toEndOf="@id/tvFilterNameA"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent">

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_marginTop="6dp"
                            android:background="@drawable/bg_graph_border" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="?attr/colorSurface"
                            android:paddingHorizontal="4dp"
                            android:text="Water Usage Over Time"
                            android:textColor="#757575"
                            android:textSize="9sp"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintHorizontal_bias="0.13"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            tools:ignore="HardcodedText" />

                        <com.github.mikephil.charting.charts.LineChart
                            android:id="@+id/chartFilterA"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_marginHorizontal="2dp"
                            android:layout_marginBottom="2dp"
                            android:layout_marginTop="10dp"
                            tools:visibility="visible" />
                    </androidx.constraintlayout.widget.ConstraintLayout>

                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:strokeColor="#E0E0E0"
                app:strokeWidth="1dp">
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="12dp">

                    <TextView
                        android:id="@+id/tvFilterLabelB"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Filter"
                        android:textSize="10sp"
                        android:textColor="#757575"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        tools:ignore="HardcodedText" />

                    <TextView
                        android:id="@+id/tvFilterNameB"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="B"
                        android:textSize="44sp"
                        android:textStyle="bold"
                        android:textColor="#000000"
                        app:layout_constraintTop_toBottomOf="@id/tvFilterLabelB"
                        app:layout_constraintStart_toStartOf="parent"
                        tools:ignore="HardcodedText" />

                    <LinearLayout
                        android:id="@+id/llStatusBadgeB"
                        android:layout_width="wrap_content"
                        android:layout_height="22dp"
                        android:orientation="horizontal"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintEnd_toEndOf="parent">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:text="STATUS:"
                            android:textColor="#FFFFFF"
                            android:textSize="9sp"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:background="@drawable/bg_status_left"
                            android:paddingHorizontal="8dp"
                            tools:ignore="HardcodedText" />
                        <TextView
                            android:id="@+id/subBText"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:text="Good"
                            android:textColor="#000000"
                            android:textSize="9sp"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:background="@drawable/bg_status_right"
                            android:paddingHorizontal="8dp"
                            app:drawableStartCompat="@drawable/ic_tick_sub"
                            android:drawablePadding="4dp"
                            tools:ignore="HardcodedText" />
                    </LinearLayout>

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/clGraphContainerB"
                        android:layout_width="0dp"
                        android:layout_height="70dp"
                        android:layout_marginStart="16dp"
                        android:layout_marginTop="4dp"
                        app:layout_constraintTop_toBottomOf="@id/llStatusBadgeB"
                        app:layout_constraintStart_toEndOf="@id/tvFilterNameB"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent">

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_marginTop="6dp"
                            android:background="@drawable/bg_graph_border" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="?attr/colorSurface"
                            android:paddingHorizontal="4dp"
                            android:text="Water Usage Over Time"
                            android:textColor="#757575"
                            android:textSize="9sp"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintHorizontal_bias="0.13"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            tools:ignore="HardcodedText" />

                        <com.github.mikephil.charting.charts.LineChart
                            android:id="@+id/chartFilterB"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_marginHorizontal="2dp"
                            android:layout_marginBottom="2dp"
                            android:layout_marginTop="10dp"
                            tools:visibility="visible" />
                    </androidx.constraintlayout.widget.ConstraintLayout>

                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:strokeColor="#E0E0E0"
                app:strokeWidth="1dp">
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="12dp">

                    <TextView
                        android:id="@+id/tvFilterLabelC"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Filter"
                        android:textSize="10sp"
                        android:textColor="#757575"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        tools:ignore="HardcodedText" />

                    <TextView
                        android:id="@+id/tvFilterNameC"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="C"
                        android:textSize="44sp"
                        android:textStyle="bold"
                        android:textColor="#000000"
                        app:layout_constraintTop_toBottomOf="@id/tvFilterLabelC"
                        app:layout_constraintStart_toStartOf="parent"
                        tools:ignore="HardcodedText" />

                    <LinearLayout
                        android:id="@+id/llStatusBadgeC"
                        android:layout_width="wrap_content"
                        android:layout_height="22dp"
                        android:orientation="horizontal"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintEnd_toEndOf="parent">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:text="STATUS:"
                            android:textColor="#FFFFFF"
                            android:textSize="9sp"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:background="@drawable/bg_status_left"
                            android:paddingHorizontal="8dp"
                            tools:ignore="HardcodedText" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:id="@+id/subAText"
                            android:text="Good"
                            android:textColor="#000000"
                            android:textSize="9sp"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:background="@drawable/bg_status_right"
                            android:paddingHorizontal="8dp"
                            app:drawableStartCompat="@drawable/ic_tick_sub"
                            android:drawablePadding="4dp"
                            tools:ignore="HardcodedText" />
                    </LinearLayout>

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/clGraphContainerC"
                        android:layout_width="0dp"
                        android:layout_height="70dp"
                        android:layout_marginStart="16dp"
                        android:layout_marginTop="4dp"
                        app:layout_constraintTop_toBottomOf="@id/llStatusBadgeC"
                        app:layout_constraintStart_toEndOf="@id/tvFilterNameC"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent">

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_marginTop="6dp"
                            android:background="@drawable/bg_graph_border" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="?attr/colorSurface"
                            android:paddingHorizontal="4dp"
                            android:text="Water Usage Over Time"
                            android:textColor="#757575"
                            android:textSize="9sp"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintHorizontal_bias="0.13"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            tools:ignore="HardcodedText" />

                        <com.github.mikephil.charting.charts.LineChart
                            android:id="@+id/chartFilterC"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_marginHorizontal="2dp"
                            android:layout_marginBottom="2dp"
                            android:layout_marginTop="10dp"
                            tools:visibility="visible" />
                    </androidx.constraintlayout.widget.ConstraintLayout>

                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvSubFilters"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:visibility="visible"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>

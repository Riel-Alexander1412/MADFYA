<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_gravity="start">

    <!-- Main content -->
    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#F5F6FA">

        <com.google.android.material.appbar.AppBarLayout
            android:id="@+id/app_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFFFFF"
            app:elevation="2dp">

            <androidx.appcompat.widget.Toolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <ImageButton
                    android:id="@+id/btn_menu"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Menu"
                    android:src="@drawable/ic_menu"
                    app:tint="#333333" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="end"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageButton
                        android:id="@+id/btn_notifications"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="Notifications"
                        android:src="@drawable/ic_notifications"
                        app:tint="#333333" />

                    <ImageButton
                        android:id="@+id/btn_profile"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_marginStart="4dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="Profile"
                        android:src="@drawable/ic_person"
                        app:tint="#333333" />

                </LinearLayout>

            </androidx.appcompat.widget.Toolbar>

        </com.google.android.material.appbar.AppBarLayout>

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            app:layout_behavior="@string/appbar_scrolling_view_behavior">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingBottom="100dp">

                <TextView
                    android:id="@+id/tv_welcome"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="Welcome, User"
                    android:textColor="#111111"
                    android:textSize="26sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Dashboard"
                    android:textColor="#1A5C8F"
                    android:textSize="14sp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="3dp"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="16dp"
                    android:background="#1A5C8F" />

                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:columnCount="2"
                    android:rowCount="2">

                    <!-- PH Level -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/card_ph"
                        android:layout_width="0dp"
                        android:layout_height="110dp"
                        android:layout_columnWeight="1"
                        android:layout_marginEnd="6dp"
                        android:layout_marginBottom="12dp"
                        app:cardBackgroundColor="#FFF3E0"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="2dp">
                        <androidx.constraintlayout.widget.ConstraintLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:padding="12dp">
                            <ImageView android:id="@+id/icon_ph" android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_ph"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toTopOf="parent"
                                app:tint="#E65100" />
                            <TextView android:id="@+id/badge_ph" android:layout_width="wrap_content" android:layout_height="wrap_content" android:background="@drawable/bg_badge_normal" android:paddingStart="8dp" android:paddingEnd="8dp" android:paddingTop="2dp" android:paddingBottom="2dp" android:text="Normal" android:textColor="#2E7D32" android:textSize="10sp" app:layout_constraintEnd_toEndOf="parent" app:layout_constraintTop_toTopOf="parent" />
                            <TextView android:id="@+id/label_ph" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="PH Level" android:textColor="#BF360C" android:textSize="13sp" android:textStyle="bold" app:layout_constraintBottom_toTopOf="@id/tv_ph_value" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toBottomOf="@id/icon_ph" app:layout_constraintVertical_chainStyle="packed" />
                            <TextView android:id="@+id/tv_ph_value" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="–" android:textColor="#111111" android:textSize="30sp" android:textStyle="bold" app:layout_constraintBottom_toBottomOf="parent" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toBottomOf="@id/label_ph" />
                        </androidx.constraintlayout.widget.ConstraintLayout>
                    </androidx.cardview.widget.CardView>

                    <!-- Turbidity -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/card_turbidity"
                        android:layout_width="0dp"
                        android:layout_height="110dp"
                        android:layout_columnWeight="1"
                        android:layout_marginStart="6dp"
                        android:layout_marginBottom="12dp"
                        app:cardBackgroundColor="#E0F7FA"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="2dp">
                        <androidx.constraintlayout.widget.ConstraintLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:padding="12dp">
                            <ImageView android:id="@+id/icon_turbidity" android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_water_drop"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toTopOf="parent"
                                app:tint="#00838F" />
                            <TextView android:id="@+id/badge_turbidity" android:layout_width="wrap_content" android:layout_height="wrap_content" android:background="@drawable/bg_badge_normal" android:paddingStart="8dp" android:paddingEnd="8dp" android:paddingTop="2dp" android:paddingBottom="2dp" android:text="Normal" android:textColor="#2E7D32" android:textSize="10sp" app:layout_constraintEnd_toEndOf="parent" app:layout_constraintTop_toTopOf="parent" />
                            <TextView android:id="@+id/label_turbidity" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="Turbidity" android:textColor="#006064" android:textSize="13sp" android:textStyle="bold" app:layout_constraintBottom_toTopOf="@id/tv_turbidity_value" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toBottomOf="@id/icon_turbidity" app:layout_constraintVertical_chainStyle="packed" />
                            <TextView android:id="@+id/tv_turbidity_value" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="–" android:textColor="#111111" android:textSize="30sp" android:textStyle="bold" app:layout_constraintBottom_toBottomOf="parent" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toBottomOf="@id/label_turbidity" />
                        </androidx.constraintlayout.widget.ConstraintLayout>
                    </androidx.cardview.widget.CardView>

                    <!-- Temperature -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/card_temperature"
                        android:layout_width="0dp"
                        android:layout_height="110dp"
                        android:layout_columnWeight="1"
                        android:layout_marginEnd="6dp"
                        app:cardBackgroundColor="#FCE4EC"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="2dp">
                        <androidx.constraintlayout.widget.ConstraintLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:padding="12dp">
                            <ImageView android:id="@+id/icon_temperature" android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_thermometer"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toTopOf="parent"
                                app:tint="#C62828" />
                            <TextView android:id="@+id/badge_temperature" android:layout_width="wrap_content" android:layout_height="wrap_content" android:background="@drawable/bg_badge_normal" android:paddingStart="8dp" android:paddingEnd="8dp" android:paddingTop="2dp" android:paddingBottom="2dp" android:text="Normal" android:textColor="#2E7D32" android:textSize="10sp" app:layout_constraintEnd_toEndOf="parent" app:layout_constraintTop_toTopOf="parent" />
                            <TextView android:id="@+id/label_temperature" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="Temperature" android:textColor="#B71C1C" android:textSize="13sp" android:textStyle="bold" app:layout_constraintBottom_toTopOf="@id/tv_temperature_value" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toBottomOf="@id/icon_temperature" app:layout_constraintVertical_chainStyle="packed" />
                            <TextView android:id="@+id/tv_temperature_value" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="–" android:textColor="#111111" android:textSize="30sp" android:textStyle="bold" app:layout_constraintBottom_toBottomOf="parent" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toBottomOf="@id/label_temperature" />
                        </androidx.constraintlayout.widget.ConstraintLayout>
                    </androidx.cardview.widget.CardView>

                    <!-- Water Usage -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/card_water_flow"
                        android:layout_width="0dp"
                        android:layout_height="110dp"
                        android:layout_columnWeight="1"
                        android:layout_marginStart="6dp"
                        app:cardBackgroundColor="#E8F5E9"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="2dp">
                        <androidx.constraintlayout.widget.ConstraintLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:padding="12dp">
                            <ImageView android:id="@+id/icon_flow" android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_water_drop"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toTopOf="parent"
                                app:tint="#2E7D32" />
                            <TextView android:id="@+id/badge_flow" android:layout_width="wrap_content" android:layout_height="wrap_content" android:background="@drawable/bg_badge_normal" android:paddingStart="8dp" android:paddingEnd="8dp" android:paddingTop="2dp" android:paddingBottom="2dp" android:text="Normal" android:textColor="#2E7D32" android:textSize="10sp" app:layout_constraintEnd_toEndOf="parent" app:layout_constraintTop_toTopOf="parent" />
                            <TextView android:id="@+id/label_flow" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="Water Usage" android:textColor="#1B5E20" android:textSize="13sp" android:textStyle="bold" app:layout_constraintBottom_toTopOf="@id/tv_flow_value" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toBottomOf="@id/icon_flow" app:layout_constraintVertical_chainStyle="packed" />
                            <TextView android:id="@+id/tv_flow_value" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="–" android:textColor="#111111" android:textSize="30sp" android:textStyle="bold" app:layout_constraintBottom_toBottomOf="parent" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toBottomOf="@id/label_flow" />
                        </androidx.constraintlayout.widget.ConstraintLayout>
                    </androidx.cardview.widget.CardView>

                </GridLayout>

                <!-- System Health -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/card_health"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="2dp">
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp">
                        <TextView android:id="@+id/tv_health_title" android:layout_width="0dp" android:layout_height="wrap_content" android:text="System Health" android:textColor="#111111" android:textSize="16sp" android:textStyle="bold" app:layout_constraintEnd_toStartOf="@id/health_gauge" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toTopOf="parent" />
                        <TextView android:id="@+id/tv_health_subtitle" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="System is currently healthy." android:textColor="#777777" android:textSize="12sp" app:layout_constraintBottom_toBottomOf="parent" app:layout_constraintEnd_toStartOf="@id/health_gauge" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toBottomOf="@id/tv_health_title" />
                        <com.mobile.madfya.ui.GaugeView android:id="@+id/health_gauge" android:layout_width="80dp" android:layout_height="80dp" app:layout_constraintBottom_toBottomOf="parent" app:layout_constraintEnd_toEndOf="parent" app:layout_constraintTop_toTopOf="parent" />
                        <TextView android:id="@+id/tv_hp_value" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="–%" android:textColor="#111111" android:textSize="16sp" android:textStyle="bold" app:layout_constraintBottom_toTopOf="@id/tv_hp_label" app:layout_constraintEnd_toEndOf="@id/health_gauge" app:layout_constraintStart_toStartOf="@id/health_gauge" app:layout_constraintTop_toTopOf="@id/health_gauge" app:layout_constraintVertical_chainStyle="packed" />
                        <TextView android:id="@+id/tv_hp_label" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="HP" android:textColor="#777777" android:textSize="11sp" app:layout_constraintBottom_toBottomOf="@id/health_gauge" app:layout_constraintEnd_toEndOf="@id/health_gauge" app:layout_constraintStart_toStartOf="@id/health_gauge" app:layout_constraintTop_toBottomOf="@id/tv_hp_value" />
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </androidx.cardview.widget.CardView>

                <!-- Announcements -->
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="24dp" android:layout_marginBottom="10dp" android:text="Announcement" android:textColor="#111111" android:textSize="18sp" android:textStyle="bold" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_announcements"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false" />


            </LinearLayout>

        </androidx.core.widget.NestedScrollView>

        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/bottom_nav"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:background="#FFFFFF"
            app:elevation="8dp"
            app:itemIconTint="@color/nav_selector"
            app:itemTextColor="@color/nav_selector"
            app:labelVisibilityMode="labeled"
            app:menu="@menu/menu_dashboard" />

    </androidx.coordinatorlayout.widget.CoordinatorLayout>

    <LinearLayout
        android:id="@+id/nav_view"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="#FFFFFF"
        android:elevation="8dp"
        android:orientation="vertical">

        <!-- ── Header ── -->

        <LinearLayout
            android:id="@+id/drawer_header"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:background="#1A5C8F"
            android:gravity="bottom"
            android:orientation="vertical"
            android:padding="24dp">

            <ImageView
                android:id="@+id/drawer_avatar"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_marginBottom="12dp"
                android:background="@drawable/bg_card_white"
                android:contentDescription="Avatar"
                android:padding="12dp"
                android:src="@drawable/ic_person"
                app:tint="#1A5C8F" />

            <TextView
                android:id="@+id/drawer_user_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="User Name"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/drawer_user_role"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Resident"
                android:textColor="#B3D9F5"
                android:textSize="13sp" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingTop="8dp">

            <!-- Reports -->
            <TextView
                android:id="@+id/nav_reports"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="?attr/selectableItemBackground"
                android:drawablePadding="16dp"
                android:gravity="center_vertical"
                android:paddingStart="24dp"
                android:paddingEnd="16dp"
                android:text="Reports"
                android:textColor="#333333"
                android:textSize="15sp"
                app:drawableStartCompat="@drawable/ic_warning"
                app:drawableTint="#1A5C8F" />

            <!-- Alerts -->
            <TextView
                android:id="@+id/nav_alerts"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="?attr/selectableItemBackground"
                android:drawablePadding="16dp"
                android:gravity="center_vertical"
                android:paddingStart="24dp"
                android:paddingEnd="16dp"
                android:text="Alerts"
                android:textColor="#333333"
                android:textSize="15sp"
                app:drawableStartCompat="@drawable/ic_notifications"
                app:drawableTint="#1A5C8F" />

            <!-- Water Safety -->
            <TextView
                android:id="@+id/nav_water_safety"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="?attr/selectableItemBackground"
                android:drawablePadding="16dp"
                android:gravity="center_vertical"
                android:paddingStart="24dp"
                android:paddingEnd="16dp"
                android:text="Water Safety"
                android:textColor="#333333"
                android:textSize="15sp"
                app:drawableStartCompat="@drawable/ic_water_drop"
                app:drawableTint="#1A5C8F" />

        </LinearLayout>

        <!-- ── Divider ── -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:background="#E0E0E0" />

        <!-- ── Bottom items pinned to the bottom ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="8dp"
            android:paddingBottom="16dp">

            <!-- Profile -->
            <TextView
                android:id="@+id/nav_profile"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="?attr/selectableItemBackground"
                android:drawablePadding="16dp"
                android:gravity="center_vertical"
                android:paddingStart="24dp"
                android:paddingEnd="16dp"
                android:text="Profile"
                android:textColor="#333333"
                android:textSize="15sp"
                app:drawableStartCompat="@drawable/ic_person"
                app:drawableTint="#1A5C8F" />

            <!-- Logout -->
            <TextView
                android:id="@+id/nav_logout"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="?attr/selectableItemBackground"
                android:drawablePadding="16dp"
                android:gravity="center_vertical"
                android:paddingStart="24dp"
                android:paddingEnd="16dp"
                android:text="Logout"
                android:textColor="#D32F2F"
                android:textSize="15sp"
                app:drawableStartCompat="@drawable/ic_logout"
                app:drawableTint="#D32F2F" />

        </LinearLayout>

    </LinearLayout>

</androidx.drawerlayout.widget.DrawerLayout>